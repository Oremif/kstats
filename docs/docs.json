{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "kstats",
  "description": "Zero-dependency Kotlin Multiplatform statistics library",
  "colors": {
    "primary": "#7F52FF",
    "light": "#A67BFF",
    "dark": "#5C3DBF"
  },
  "favicon": "/images/favicon.svg",
  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": true,
    "codeblocks": "dark"
  },
  "search": {
    "prompt": "Search kstats docs..."
  },
  "appearance": {
    "default": "system"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/Oremif/kstats"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Oremif/kstats"
    }
  },
