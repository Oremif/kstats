                    ]
                  }
                ]
              },
              {
                "tab": "Guides",
                "groups": [
                  {
                    "group": "How-To Guides",
                    "pages": [
                      "de/guides/how-to/choosing-a-distribution",
                      "de/guides/how-to/testing-assumptions",
                      "de/guides/how-to/ab-testing",
                      "de/guides/how-to/quality-control",
                      "de/guides/how-to/exploratory-analysis",
                      "de/guides/how-to/building-a-pipeline"
                    ]
